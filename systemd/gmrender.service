# AuraBridge DLNA renderer (gmediarender / gmrender-resurrect) — Phase 6.
#
# GATED + DISABLED BY DESIGN:
#   - ExecStartPre refuses to start unless the AuraBridge Safe Sink has been
#     VERIFIED (logs/safe-sink-verified.txt contains SAFE_SINK_VERIFIED=yes,
#     written only by test-safe-sink.sh). So the unit stays INERT until real-time
#     audio safety is verified.
#   - The installer does NOT enable this service automatically. Start it
#     manually: `systemctl --user start gmrender.service`. After verification,
#     an operator may explicitly opt into boot autostart.
#   - Audio routes through pipewire-pulse to the verified Safe Sink
#     (PULSE_SINK=aurabridge_safe_sink), never directly to ALSA hw:/plughw:.
#
# Installed as a USER service by scripts/install-dlna.sh (which itself refuses to
# run unless the Safe Sink is verified). See docs/dlna.md and docs/volume-safety.md.

[Unit]
Description=AuraBridge DLNA renderer (gmediarender via Safe Sink; gated, NOT enabled by default)
Documentation=file:%h/AuraBridge-Pi/docs/dlna.md
After=pipewire.service pipewire-pulse.service wireplumber.service
Wants=pipewire-pulse.service

[Service]
# Hard start-time gate: do not start unless the Safe Sink is verified for the
# currently active fixed gain.
ExecStartPre=%h/AuraBridge-Pi/scripts/check-safe-sink-gate.sh
# gmediarender can start before wlan0 has an address after a hard power cycle.
# In that case it stays "active" but never binds SSDP UDP 1900, so phones cannot
# discover it. Wait for a real IPv4 interface before starting.
Environment=AURABRIDGE_DISCOVERY_IFACE=wlan0
ExecStartPre=/bin/sh -c 'iface="${AURABRIDGE_DISCOVERY_IFACE:-wlan0}"; for i in $(seq 1 60); do ip -o -4 addr show dev "$iface" up scope global | grep -q "inet " && exit 0; sleep 1; done; echo "No global IPv4 address on ${iface} for DLNA startup" >&2; exit 1'
# Route through pipewire-pulse to the verified Safe Sink (NOT ALSA hardware).
Environment=PULSE_SINK=aurabridge_safe_sink
# Stable identity: AURABRIDGE_DLNA_UUID is generated once and persisted by
# install-dlna.sh so control points recognise the SAME renderer across reboots.
# The unit fails loudly if it is missing (run install-dlna.sh first).
EnvironmentFile=%h/.config/aurabridge/dlna-uuid
# --uuid keeps the device identity stable; --port pins the HTTP/SOAP port (SSDP
# discovery itself is multicast UDP 1900) so it is predictable for firewall rules
# and for check-dlna-discovery.sh.
ExecStart=/usr/bin/gmediarender --interface-name ${AURABRIDGE_DISCOVERY_IFACE} --friendly-name "Aura Studio 3 DLNA" --gstout-audiosink pulsesink --uuid ${AURABRIDGE_DLNA_UUID} --port 49494
# Treat "process is active but SSDP did not bind" as a failed start so systemd
# restarts it instead of leaving a non-discoverable renderer running.
ExecStartPost=/bin/sh -c 'for i in $(seq 1 20); do ss -lun 2>/dev/null | grep -q ":1900" && ss -ltn 2>/dev/null | grep -q ":49494" && exit 0; sleep 1; done; echo "gmediarender did not bind SSDP UDP 1900 and HTTP TCP 49494" >&2; exit 1'
Restart=on-failure
RestartSec=5

# The installer does not enable this unit. Keep [Install] so a verified system
# can explicitly opt into autostart without hand-editing the unit.
[Install]
WantedBy=default.target
